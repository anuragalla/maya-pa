# --- Service ---
LIVE150_ENV=dev
LIVE150_LOG_LEVEL=INFO
LIVE150_HTTP_HOST=0.0.0.0
LIVE150_HTTP_PORT=8000

# --- Database ---
LIVE150_DB_URL_ASYNC=postgresql+asyncpg://live150:live150dev@postgres:5432/live150
LIVE150_DB_URL_SYNC=postgresql://live150:live150dev@postgres:5432/live150
POSTGRES_PASSWORD=live150dev

# --- Auth ---
LIVE150_JWT_ISSUER=https://auth.live150.example
LIVE150_JWT_AUDIENCE=live150-agent
LIVE150_JWT_ALGORITHM=RS256
LIVE150_JWT_JWKS_URL=https://auth.live150.example/.well-known/jwks.json
LIVE150_JWT_JWKS_CACHE_SECONDS=600

# --- Vertex AI / Google Gen AI SDK ---
# google-genai and ADK read these three directly from the process env.
# GOOGLE_CLOUD_LOCATION=global is required for Gemini 3.1 preview models
# (e.g. gemini-3-1-flash-lite) — regional endpoints return model-not-found.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=live150-dev
GOOGLE_CLOUD_LOCATION=global

# App-level duplicates: kept separate so the embedder can pin a regional
# endpoint (text-embedding-005 is GA, regional) while the ADK agent loop
# and any 3.1-preview calls target `global`.
LIVE150_GCP_PROJECT=live150-dev
LIVE150_GCP_REGION=us-central1
LIVE150_GCP_PREVIEW_REGION=global
LIVE150_DEFAULT_MODEL=gemini-3-flash
LIVE150_LITE_MODEL=gemini-3-1-flash-lite
LIVE150_EMBEDDING_MODEL=text-embedding-005

# --- Live150 APIs ---
LIVE150_API_BASE=https://api.live150.example
LIVE150_NOTIFY_URL=https://notify.live150.example/send
LIVE150_SERVICE_API_TOKEN=dev-service-token

# --- Live150 dev-route auth ---
# Dev: LIVE150_DEV_TOKEN exchanges for a per-user access token via
#   POST /api/v1/login/developer/impersonate (impersonation).
# Prod: LIVE150_BEARER_TOKEN is the already-issued per-user token — skip
#   impersonation and pass it through to the five user-scoped GETs.
# LIVE150_USE_MOCK=true swaps in an in-memory mock for local dev/tests.
LIVE150_DEV_TOKEN=
LIVE150_BEARER_TOKEN=
LIVE150_USE_MOCK=false
LIVE150_HTTP_TIMEOUT_SECONDS=30

# --- OAuth ---
GOOGLE_OAUTH_CLIENT_ID=your-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
LIVE150_OAUTH_REDIRECT_BASE=http://localhost:8000

# --- Crypto ---
LIVE150_MASTER_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- Misc ---
LIVE150_PROFILE_TTL_MINUTES=60
LIVE150_RATE_LIMIT_CHAT_PER_5MIN=60
LIVE150_RATE_LIMIT_REMINDERS_PER_MIN=10
