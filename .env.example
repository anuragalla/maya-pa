# Copy to .env and fill in values. Never commit real keys.

# --- Database ---
POSTGRES_PASSWORD=live150dev
LIVE150_DB_URL_ASYNC=postgresql+asyncpg://live150:live150dev@postgres:5432/live150
LIVE150_DB_URL_SYNC=postgresql://live150:live150dev@postgres:5432/live150

# --- GCP / Gemini ---
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
LIVE150_GEMINI_API_KEY=<your-gemini-api-key>

# --- Live150 API ---
LIVE150_API_BASE=http://liv150-api-api-1:8001
LIVE150_LIV150_API_BASE=http://liv150-api-api-1:8001
LIVE150_DEV_TOKEN=

# --- Crypto ---
LIVE150_MASTER_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- Google OAuth (Calendar) ---
LIVE150_OAUTH_REDIRECT_BASE=http://localhost:8000/api/v1
LIVE150_OAUTH_SUCCESS_REDIRECT=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=<your-google-oauth-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<your-google-oauth-client-secret>

# --- Gate auth ---
LIVE150_GATE_USERNAME=maya
LIVE150_GATE_PASSWORD=<gate-password>
LIVE150_GATE_JWT_SECRET=<gate-jwt-secret>

# --- JWT (must match liv150-api's secret for voice WS auth) ---
LIVE150_JWT_SECRET=<jwt-secret>
LIVE150_JWT_ALGORITHM=HS256

# --- Notifications ---
LIVE150_NOTIFY_URL=http://agent:8000/api/v1/notifications/push
