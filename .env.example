# --- Service ---
LIVE150_ENV=dev
LIVE150_LOG_LEVEL=INFO
LIVE150_HTTP_PORT=8000

# --- Database ---
LIVE150_DB_URL_ASYNC=postgresql+asyncpg://live150:live150dev@postgres:5432/live150
LIVE150_DB_URL_SYNC=postgresql://live150:live150dev@postgres:5432/live150
POSTGRES_PASSWORD=live150dev

# Gemini
LIVE150_GEMINI_API_KEY=<your-gemini-api-key>

# --- Live150 API ---
LIVE150_API_BASE=https://lifecloud.eng.sandbox.healthhustler.io
LIVE150_DEV_TOKEN=

# --- Crypto ---
LIVE150_MASTER_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=


# --- OAuth ---
LIVE150_OAUTH_REDIRECT_BASE=http://localhost:8000/api/v1
LIVE150_OAUTH_SUCCESS_REDIRECT=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=<your-google-oauth-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<your-google-oauth-client-secret>
